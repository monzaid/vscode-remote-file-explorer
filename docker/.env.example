# =============================================================================
# Docker Test Environment — Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Change all "changeme" passwords to strong, unique values
#   3. The .env file is git-ignored — never commit it to version control
# =============================================================================

# --- SSH Server (linuxserver/openssh-server) ---
SSH_USER=testuser
SSH_PASSWORD=changeme
SSH_PASSWORD_ACCESS=true
SSH_SUDO_ACCESS=false
# For production: set SSH_PASSWORD_ACCESS=false and mount SSH public keys
# See: https://docs.linuxserver.io/images/docker-openssh-server/#key-based-authentication

# --- FTP Server (fauria/vsftpd) ---
FTP_USER=ftpuser
FTP_PASS=changeme
FTP_ANONYMOUS_ENABLE=NO
FTP_PASV_ADDRESS=127.0.0.1

# --- Port Mapping ---
TEST_SSH_PORT=2222
TEST_FTP_PORT=2121
